# Requerido
OPENAI_API_KEY=your_openai_api_key_here

# Requerido — texto a convertir en audio
INPUT_TEXT=Bienvenidos al podcast de tecnología e inteligencia artificial.

# Opcional (default: profesional) — opciones: profesional | amigable | narradora | energetico | neutral | dramatico
VOICE_STYLE=profesional

# Opcional (default: hd) — opciones: hd | standard
QUALITY=hd
