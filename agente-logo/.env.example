# Requerido
OPENAI_API_KEY=your_openai_api_key_here

# Requerido — descripción de la marca / empresa
PROMPT=Startup de tecnología financiera para jóvenes en Argentina

# Opcional (default: startup) — opciones: minimalista | corporativo | startup | vintage | luxury | playful
STYLE=startup

# Opcional (default: 2, máximo: 3) — cantidad de variaciones del logo
VARIATIONS=2
